# API Configuration (Backend Próprio - sem Base44)

# Local Development
VITE_API_URL=http://localhost:3000/api

# Production (Vercel) - apontar para seu backend em produção
# VITE_API_URL=https://seu-backend.vercel.app/api

# AI Agent API (Railway)
VITE_AI_AGENT_API_URL=https://crmaiagent-production.up.railway.app

# CORS — origens permitidas (separadas por vírgula)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://seu-dominio.vercel.app

# Admin secret para proteger rotas /api/seed e /api/reset
# Em produção, se não definida, essas rotas ficam bloqueadas
# ADMIN_SECRET=sua-chave-secreta-aqui
